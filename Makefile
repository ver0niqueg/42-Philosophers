################################################################################
# COLORS
################################################################################

DEFAULT = \033[0m
GREEN	= \033[1;32m
RED		= \033[1;31m

################################################################################
# CONFIG
################################################################################

NAME		= philo

CC			= cc
CFLAGS		= -Wall -Werror -Wextra

RM			= rm -f

SRCS = \
	srcs/main.c \
	srcs/init_simulation.c \
	srcs/philo_actions.c \
	srcs/philo_routine.c \
	srcs/philo_monitoring.c \
	srcs/utils_1.c \
	srcs/utils_2.c

OBJS = $(SRCS:.c=.o)

################################################################################
# RULES
################################################################################

all: $(NAME)

################################################################################
# PHILO
################################################################################

$(NAME): $(OBJS)
	@$(CC) $(CFLAGS) $(OBJS) -o $(NAME)
	@printf "$(GREEN)[OK]$(DEFAULT) philo compiled\n"

################################################################################
# OBJECTS
################################################################################

%.o: %.c
	@$(CC) $(CFLAGS) -c $< -o $@

################################################################################
# CLEAN
################################################################################

clean:
	@$(RM) $(OBJS)
	@printf "$(RED)[CLEAN]$(DEFAULT) object files removed\n"

fclean: clean
	@$(RM) $(NAME)
	@printf "$(RED)[FCLEAN]$(DEFAULT) executable removed\n"

re: fclean all

.PHONY: all clean fclean re